# Flask configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=dev_secret_key_sea_1_mcq_battle
JWT_SECRET_KEY=jwt_secret_key_sea_1_mcq_battle

# Database configuration
# For MySQL: mysql+pymysql://username:password@endpoint:3306/mcq_battle
# For PostgreSQL: postgresql://username:password@localhost:5432/mcq_battle
# For Supabase Postgres: postgresql://username:password@db.host.supabase.co:5432/postgres
# Default SQLite fallback for zero-configuration local execution:
DATABASE_URL=sqlite:///mcq_battle.db
# You may also set SUPABASE_DB_URL instead of DATABASE_URL for Supabase.
SUPABASE_DB_URL=postgresql://username:password@db.host.supabase.co:5432/postgres

# Shared SSO secret from padikkunnundo.app
JWT_SECRET=your_padikkunnundo_jwt_secret

# Dynamic Admin Credentials configuration
ADMIN_USERNAME=your_secure_admin_username
ADMIN_PASSWORD=your_super_secure_password

